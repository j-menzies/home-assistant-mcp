# MCP Server Configuration
MCP_API_KEY=             # Generated on first run, or set manually
MCP_PORT=3000
MCP_HOST=127.0.0.1
NODE_ENV=development

# Home Assistant Configuration
HA_BASE_URL=http://192.168.1.33:8123   # Development: Pi's IP. Production: http://localhost:8123
HA_TOKEN=                               # Long-Lived Access Token from HA

# Development Options
MCP_SKIP_AUTH=false      # Set to true to skip API key auth during early testing
